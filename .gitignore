# Software-under-test: bare stores + worktrees under software/<name>/ (see
# .host-software, call/0010; plan/0029). Materialized locally from the recipe;
# never tracked.
/software/

# Skill symlink into the worktree — local, recreated after materialize. Tracking
# it would dangle in a fresh clone / CI (worktree-absence coherence, call/0011).
/.claude/skills/*

# Generated by `host-lifecycle book` (the canonical publisher, call/0014) and by
# mdBook; never committed, regenerated by CI before the build. book.toml stays at
# the root; the source and built HTML live under mdBook/ (mdBook/src + mdBook/out),
# leaving docs/ free for authored content (plan/0046, host-lifecycle#3).
/book.toml
/mdBook/

# personal Claude Code overrides (not tracked)
.claude/settings.local.json

# The local environment fingerprint: this machine's state, never shared.
.host-envhash
