[software "host"]
	# the single-file entrance (the methodology's entry point), set apart from the
	# host-* tools: it is the entrance, not a component (plan/0039). Declared in the
	# `[entrance]` stanza below (plan/0043).
	url       = https://github.com/connollydavid/host.git
	pin       = 699d423033bb3f04234f7e6c7edb562a9f8f75f6
	worktrees =

# The single-file entrance (plan/0043): the `host` member's README, held complete against
# every concept. A global singleton; `host-lifecycle entrance --check` holds it to the spine.
[entrance]
	member   = host
	document = README.md
	restates = true

# The verification ladder's drivers (plan/0039): the project-local `verifiers`, sourced
# here rather than the shared spine manifest. A doc that names the verifiers must name this
# whole set; the reconcile coverage check holds the home in STRUCTURE.md to it.
[verification]
	drivers = host-lint allium specula host-prove
